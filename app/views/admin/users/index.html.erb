<body class="g-sidenav-show  bg-gray-100">
  <!-- End Navbar -->
  <div class="container-fluid py-2">
    <div class="row">
      <div class="col-12">
        <div class="card my-4">
          <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
            <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
              <h6 class="text-white text-capitalize ps-3">Users</h6>
            </div>
          </div>
          <div class="card-body px-0 pb-2">
            <div class="px-3 pb-3">
              <%= form_with url: admin_users_path, method: :get, local: true do %>
                <div class="row justify-content-end align-items-center">
                  <div class="col-md-4 col-sm-6">
                    <div class="input-group input-group-outline">
                      <%= text_field_tag :search, params[:search],
              class: "form-control",
              placeholder: "Search users..." %>
                    </div>
                  </div>
                  <div class="col-md-1 col-sm-4">
                    <%= submit_tag "Search", class: "btn bg-gradient-info w-100 mb-0" %>
                  </div>
                  <% if params[:search].present? %>
                    <div class="col-md-2 col-sm-4">
                      <%= link_to "Reset", admin_users_path, class: "btn btn-outline-secondary w-100 mb-0" %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
            <div class="table-responsive p-0">
              <table class="table align-items-center mb-0">
                <thead>
                  <tr>
                    <th class="text-uppercase text-dark text-xxs font-weight-bold">Id</th>
                    <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Name</th>
                    <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Email</th>
                    <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Contact Number</th>
                    <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Active Store</th>
                    <%# <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Status</th> %>
                    <th class="text-uppercase text-dark text-xxs font-weight-bold text-center">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @users.each_with_index do |user, index| %>
                    <tr>
                      <!-- ID -->
                      <td>
                        <p class="text-xs font-weight-bold mb-0 px-3 py-1"><%= (@users.current_page - 1) * @users.limit_value + index + 1 %>
                        </p>
                      </td>
                      <!-- Name -->
                      <td>
                        <div class="d-flex px-2 py-1">
                          <div class="d-flex flex-column justify-content-center">
                            <h6 class="mb-0 text-sm"><%= user.name.titleize %></h6>
                          </div>
                        </div>
                      </td>
                      <!-- Email -->
                      <td>
                        <p class="text-sm text-secondary mb-0 font-weight-bold"><%= user.email || "—" %></p>
                      </td>
                      <!-- Contact Number -->
                      <td>
                        <p class="text-sm text-secondary mb-0 font-weight-bold">
                          <%= user.contact_number.presence || "—" %>
                        </p>
                      </td>
                      <!-- Active Store -->
                      <td>
                        <p class="text-sm text-secondary mb-0 font-weight-bold">
                          <%= user.active_store_id || "—" %>
                        </p>
                      </td>
                      <!-- Actions -->
                      <td class="align-middle text-center">
                        <div class="d-flex justify-content-center gap-1">
                          <!-- Show -->
                          <%= link_to admin_user_path(user), class: "btn btn-xs rounded btn-secondary", title: "Show" do %>
                            <i class="fas fa-eye"></i>
                          <% end %>
                          <!-- Edit -->
                          <%= link_to edit_admin_user_path(user), class: "btn btn-xs rounded btn-secondary", title: "Edit" do %>
                            <i class="fas fa-edit"></i>
                          <% end %>
                          <!-- Delete -->
                          <%= button_to admin_user_path(user), method: :delete, onclick: "return confirm('Are you sure you want to delete this user?')", class: "btn btn-xs rounded btn-secondary", form: { class: "d-inline" }, title: "Delete" do %>
                            <i class="fas fa-trash"></i>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
            <div class="d-flex justify-content-center px-3 mt-3">
              <%= paginate @users %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
