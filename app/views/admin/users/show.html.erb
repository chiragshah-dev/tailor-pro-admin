<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <!-- PAGE HEADER -->
      <div class="card mb-4">
        <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
          <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3 d-flex justify-content-between align-items-center">
            <h6 class="text-white text-capitalize ps-3 mb-0">
              User Details
            </h6>
            <div class="me-3">
              <div class="me-3 d-flex gap-2">
                <button
    class="btn btn-sm btn-white text-dark text-uppercase font-weight-bold"
    type="button"
    data-bs-toggle="collapse"
    data-bs-target="#userStores"
    aria-expanded="false"
    aria-controls="userStores">
                  Stores
                </button>
                <%= link_to edit_admin_user_path(@user), class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold me-2" do %>
                  Edit 
                <% end %>
                <%= link_to admin_user_path(@user), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold" do %>
                  Delete 
                <% end %>
              </div>
            </div>
          </div>
          <!-- USER DETAILS BODY -->
          <div class="card-body px-4 pt-4 pb-2">
            <div class="row">
              <!-- LEFT COLUMN -->
              <div class="col-md-6">
                <p class="text-sm mb-2">
                  <span class="fw-bold text-dark">ID:</span>
                  <span class="text-sm text-secondary mb-0 font-weight-bold ms-2"><%= @user.id %></span>
                </p>
                <p class="text-sm mb-2">
                  <span class="fw-bold text-dark">Name:</span>
                  <span class="text-sm text-secondary mb-0 font-weight-bold ms-2"><%= @user.name.titleize %></span>
                </p>
                <p class="text-sm mb-2">
                  <span class="fw-bold text-dark">Email:</span>
                  <span class="text-sm text-secondary mb-0 font-weight-bold ms-2"><%= @user.email || "—" %></span>
                </p>
                <p class="text-sm mb-2">
                  <span class="fw-bold text-dark">Country Code:</span>
                  <span class="text-sm text-secondary mb-0 font-weight-bold ms-2">
                    <%= @user.country_code.presence || "—" %>
                  </span>
                </p>
              </div>
              <!-- RIGHT COLUMN -->
              <div class="col-md-6">
                <p class="text-sm mb-2">
                  <span class="fw-bold text-dark">Active Store:</span>
                  <span class="text-sm text-secondary mb-0 font-weight-bold ms-2">
                    <%= @user.active_store_id || "—" %>
                  </span>
                </p>
                <p class="text-sm mb-2">
                  <span class="fw-bold text-dark">Created At:</span>
                  <span class="text-sm text-secondary mb-0 font-weight-bold ms-2">
                    <%= @user.created_at.strftime("%d %B %Y, %I:%M %p") %>
                  </span>
                </p>
                <p class="text-sm mb-2">
                  <span class="fw-bold text-dark">Updated At:</span>
                  <span class="text-sm text-secondary mb-0 font-weight-bold ms-2">
                    <%= @user.updated_at.strftime("%d %B %Y, %I:%M %p") %>
                  </span>
                </p>
                <p class="text-sm mb-2">
                  <span class="fw-bold text-dark">Contact Number:</span>
                  <span class="text-sm text-secondary mb-0 font-weight-bold ms-2">
                    <%= @user.contact_number.presence || "—" %>
                  </span>
                </p>
              </div>
            </div>
            <div class="collapse mt-4" id="userStores">
              <hr class="horizontal dark mb-3">
              <h6 class="text-uppercase text-dark mb-3">
                User Stores
              </h6>
              <% if @user.stores.any? %>
                <div class="row">
                  <% @stores.each do |store| %>
                    <div class="col-md-6 mb-3">
                      <div class="card shadow-sm h-100 <%= 'border border-info' if store.is_main_store %>">
                        <div class="card-body p-3">
                          <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="mb-0">
                              <%= store.name %>
                            </h6>
                            <% if store.is_main_store %>
                              <div class="bg-gradient-info text-white px-3 py-2 rounded-top">
                                Main Store
                              </div>
                            <% end %>
                          </div>
                          <p class="text-sm mb-1 text-dark">
                            <strong>Code:</strong>
                            <span class="text-secondary"><%= store.code %><%= store.id %></span>
                          </p>
                          <p class="text-sm mb-1 text-dark">
                            <strong>Stiched For:</strong>
                            <span class="text-secondary text-capitalize">
                              <%= store.stitches_for %>
                            </span>
                          </p>
                          <p class="text-sm mb-1 text-dark">
                            <strong>Contact:</strong>
                            <span class="text-secondary">
                              <%= store.contact_number.presence || "—" %>
                            </span>
                          </p>
                          <p class="text-sm mb-1 text-dark">
                            <strong>Is Main Store:</strong>
                            <span class="text-secondary">
                              <%= store.is_main_store ? "Yes" : "No" %>
                            </span>
                          </p>
                          <div class="mt-3 d-flex justify-content-end gap-2">
                            <%#= link_to admin_store_path(store),
                    class: "btn btn-xs btn-secondary" do %>
                              <%# View %>
                              <%# end %>
                              <%#= link_to edit_admin_store_path(store),
                    class: "btn btn-xs btn-outline-secondary" do %>
                                <%# Edit %>
                                <%# end %>
                              </div>
                            </div>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <p class="text-sm text-secondary mb-0">
                      This user has no stores.
                    </p>
                  <% end %>
                </div>
                <%= link_to admin_users_path, class: "btn btn-secondary btn-sm text-uppercase font-weight-bold float-end" do %>
                  Back
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
