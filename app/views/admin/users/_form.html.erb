<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="card my-4">
        <!-- HEADER (same as index page) -->
        <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
          <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
            <h6 class="text-white text-capitalize ps-3 mb-0">
              Edit User
            </h6>
          </div>
        </div>
        <!-- BODY -->
        <div class="card-body px-4 pb-4">
          <%= form_with model: [:admin, @user], local: true do |f| %>
            <div class="row g-4">
              <div class="col-md-6">
                <label class="form-label font-weight-bold text-dark">Full Name</label>
                <div class="input-group input-group-outline">
                  <%= f.text_field :name, class: "form-control" %>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label font-weight-bold text-dark">Email Address</label>
                <div class="input-group input-group-outline">
                  <%= f.email_field :email, class: "form-control" %>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label font-weight-bold text-dark">Contact Number</label>
                <div class="input-group input-group-outline">
                  <%= f.text_field :contact_number, class: "form-control" %>
                </div>
              </div>
            </div>
            <!-- ACTIONS -->
            <div class="d-flex justify-content-end mt-4">
              <%= link_to "Back", admin_users_path,
                    class: "btn btn-secondary me-2 text-uppercase font-weight-bold" %>
              <%= f.submit "Update", class: "btn btn-info text-white" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
