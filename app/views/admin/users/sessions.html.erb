<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3 d-flex justify-content-between">
          <h6 class="text-white text-capitalize ps-3">
            <%= @user.name %> Sessions
          </h6>
          <div class="me-3">
            <%#= link_to admin_users_path(page: params[:page]),
              class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold" do %>
              <%# Back %>
              <%# <% end %>
            </div>
          </div>
        </div>
        <!-- BODY -->
        <div class="card-body px-0 pb-4">
          <div class="table-responsive p-0">
            <table class="table align-items-center mb-0">
              <thead>
                <tr>
                  <th class="ps-3 text-uppercase text-dark text-xxs font-weight-bold">Session</th>
                  <th class="text-uppercase text-dark text-xxs font-weight-bold">Flow</th>
                  <th class="text-uppercase text-dark text-xxs font-weight-bold">Status</th>
                  <th class="text-uppercase text-dark text-xxs font-weight-bold">Start</th>
                  <th class="text-uppercase text-dark text-xxs font-weight-bold text-center">Action</th>
                </tr>
              </thead>
              <tbody>
                <% if @app_sessions.present? %>
                  <% @app_sessions.each do |s| %>
                    <tr>
                      <td class="ps-3 text-sm text-dark">
                        <%= s.session_id %>
                      </td>
                      <td class="text-sm">
                        <span class="text-info"><%= s.entry_route %></span>
                        →
                        <span class="text-danger"><%= s.exit_route || "-" %></span>
                      </td>
                      <td>
                        <span class="badge bg-gradient-<%= s.status == "active" ? "success" : "secondary" %>">
                          <%= s.status.capitalize %>
                        </span>
                      </td>
                      <td class="text-sm text-dark">
                        <%= s.start_time.strftime("%d %b %Y %I:%M %p") %>
                      </td>
                      <td class="text-center">
                        <%= link_to session_detail_admin_user_path(@user, s.id),
                        class: "btn btn-xs btn-secondary" do %>
                          <i class="fas fa-eye"></i>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="5" class="text-center">
                      <p class="no-content-text">No sessions found.</p>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="d-flex justify-content-center mt-3">
            <%= paginate @app_sessions %>
          </div>
        </div>
      </div>
    </div>
  </div>