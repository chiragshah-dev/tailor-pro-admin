<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- Header -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
          <h6 class="text-white text-capitalize ps-3">Wallets</h6>
        </div>
      </div>
      <div class="card-body px-0 pb-2">
        <!-- Search -->
        <div class="px-3 pb-3">
          <%= render "admin/shared/search",
                    url: admin_wallets_path,
                    placeholder: "Search wallets..." %>
        </div>
        <!-- Table -->
        <div class="table-responsive p-0">
          <table class="table align-items-center mb-0">
            <thead>
              <tr>
                <th class="text-uppercase text-dark text-xxs font-weight-bold">Id</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">
                  <%= sortable_header("store", "Store") %>
                </th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">
                  <%= sortable_header("balance", "Balance") %>
                </th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">
                  <%= sortable_header("currency", "Currency") %>
                </th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold text-center">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if @wallets.present? %>
                <% @wallets.each_with_index do |wallet, index| %>
                  <tr>
                    <!-- Index -->
                    <td>
                      <p class="text-sm text-dark mb-0 px-3">
                        <%= (@wallets.current_page - 1) * @wallets.limit_value + index + 1 %>
                      </p>
                    </td>
                    <!-- Store -->
                    <td>
                      <p class="text-sm text-dark mb-0 ">
                        <% if wallet.store.present? %>
                          <%= link_to wallet.store.name,
                            admin_store_path(wallet.store),
                            class: "text-decoration-none text-info " %>
                        <% else %>
                        <% end %>
                      </p>
                    </td>
                    <!-- Balance -->
                    <td>
                      <p class="text-sm text-dark mb-0 ">
                        <%= wallet.balance || "-" %>
                      </p>
                    </td>
                    <!-- currency -->
                    <td>
                      <p class="text-sm text-dark mb-0 ">
                        <%= wallet.currency || "-" %>
                      </p>
                    </td>
                    <!-- Actions -->
                    <td class="align-middle text-center">
                      <div class="d-flex justify-content-center gap-1">
                        <%= link_to admin_wallet_path(wallet,page: params[:page]),
                                  class: "btn btn-xs rounded btn-secondary",
                                  title: "Show" do %>
                          <i class="fas fa-eye"></i>
                        <% end %>
                        <%= link_to history_admin_wallet_path(wallet),
      class: "btn btn-xs rounded btn-secondary",
      title: "View History" do %>
                          <i class="fas fa-history"></i>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="12" class="text-center">
                    <p class="no-content-text">No records found.</p>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <!-- Pagination -->
        <div class="d-flex justify-content-center px-3 mt-3">
          <%= paginate @wallets %>
        </div>
      </div>
    </div>
  </div>
</div>
