<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- PAGE HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3
                    d-flex justify-content-between align-items-center">
          <h6 class="text-white text-capitalize ps-3 mb-0">
            Custom Product Details
          </h6>
          <div class="me-3 d-flex gap-2">
            <%= link_to admin_order_path(@custom_product.order),
                  class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold",
                  data: { turbo_frame: "_top" } do %>
              View Order
            <% end %>
          </div>
        </div>
      </div>
      <!-- BODY -->
      <div class="card-body px-4 pt-4 pb-4">
        <!-- BASIC INFO -->
        <div class="row mb-3">
          <!-- LEFT -->
          <div class="col-md-6">
            <p class="text-sm mb-2 text-dark">
              <strong>Product Name:</strong>
              <span class="ms-2"><%= @custom_product.name %></span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Quantity:</strong>
              <span class="ms-2"><%= @custom_product.quantity %></span>
            </p>
          </div>
          <!-- RIGHT -->
          <div class="col-md-6">
            <p class="text-sm mb-2 text-dark">
              <strong>Price:</strong>
              <span class="ms-2">₹ <%= @custom_product.price %></span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Total:</strong>
              <span class="ms-2">
                ₹ <%= @custom_product.price.to_f * @custom_product.quantity.to_i %>
              </span>
            </p>
          </div>
        </div>
        <hr class="horizontal dark my-3">
        <!-- NOTE -->
        <h6 class="text-uppercase text-dark mb-3">Additional Information</h6>
        <p class="text-sm mb-2 text-dark">
          <strong>Note:</strong>
          <span class="ms-2">
            <%= @custom_product.note.presence || "-" %>
          </span>
        </p>
        <hr class="horizontal dark my-3">
        <!-- BACK -->
        <%= link_to admin_order_path(@custom_product.order),
              class: "btn btn-secondary btn-sm text-uppercase font-weight-bold float-end mt-3",
              data: { turbo_frame: "_top" } do %>
          Back
        <% end %>
      </div>
    </div>
  </div>
</div>