<turbo-frame id="order_measurements_frame">
  <h6 class="text-uppercase text-dark mb-3">Measurement Details</h6>
  <div class="table-responsive p-0">
    <table class="table align-items-center mb-0">
      <thead>
        <tr>
          <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">ID</th>
          <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">
            Measurement Field
          </th>
          <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">
            Member
          </th>
          <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">
            Value
          </th>
          <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">
            Unit
          </th>
          <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">Action</th>
        </tr>
      </thead>
      <tbody>
        <% if order_measurements.any? %>
          <% order_measurements.each_with_index do |m, index| %>
            <tr>
              <td class="text-center text-sm"><%= index + 1 %></td>
              <td class="text-center text-sm">
                <% if m.measurement_field.present? %>
                  <%= link_to admin_measurement_field_path(m.measurement_field),
        class: "text-decoration-none text-info",
        title: "View Measurement Field",
        data: { turbo_frame: "_top" } do %>
                    <%= m.measurement_field.name.titleize %>
                  <% end %>
                <% else %>
                  N/A
                <% end %>
              </td>
              <td class="text-center text-sm">
                <% if m.member.present? %>
                  <%= m.member.name.titleize %>
                <% else %>
                  N/A
                <% end %>
              </td>
              <td class="text-center text-sm"><%= m.value %></td>
              <td class="text-center text-sm text-uppercase"><%= m.unit %></td>
              <!-- ACTION -->
              <td class="text-center">
                <%= link_to history_admin_order_measurement_path(m),  
                        class: "btn btn-xs rounded btn-secondary",
                        title: "History",
                        data: { turbo_frame: "_top" } do %>
                  <i class="fas fa-history"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="text-center">
              <p class="no-content-text">No measurements found.</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</turbo-frame>
