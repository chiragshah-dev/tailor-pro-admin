<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- PAGE HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3
                      d-flex justify-content-between align-items-center">
          <h6 class="text-white text-capitalize ps-3 mb-0">
            Order Item Details
          </h6>
          <div class="me-3 d-flex gap-2">
            <%= link_to admin_order_path(@order_item.order),
                  class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold",
                  data: { turbo_frame: "_top" } do %>
              View Order
            <% end %>
          </div>
        </div>
      </div>
      <!-- BODY -->
      <div class="card-body px-4 pt-4 pb-4">
        <!-- BASIC INFO -->
        <div class="row mb-3">
          <!-- LEFT -->
          <div class="col-md-6">
            <p class="text-sm mb-2 text-dark">
              <strong>Item ID:</strong>
              <span class="text-dark ms-2"><%= @order_item.id %></span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Item Number:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.order_item_number %>
              </span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Work Type:</strong>
              <span class="text-dark ms-2 text-capitalize">
                <%= @order_item.work_type %>
              </span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Stitch For:</strong>
              <span class="text-dark ms-2 text-capitalize">
                <%= @order_item.stichfor %>
              </span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Garment Type:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.garment_type&.garment_name || "-" %>
              </span>
            </p>
          </div>
          <!-- RIGHT -->
          <div class="col-md-6">
            <p class="text-sm mb-2 text-dark">
              <strong>Quantity:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.quantity %>
              </span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Price:</strong>
              <span class="text-dark ms-2">
                ₹ <%= @order_item.price %>
              </span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Status:</strong>
              <span class="ms-2">
                <span class="badge badge-sm
                    <%= @order_item.status == "completed" ? "bg-gradient-success" :
                        @order_item.status == "in_progress" ? "bg-gradient-info" :
                        "bg-gradient-secondary" %>">
                  <%= @order_item.status.humanize %>
                </span>
              </span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Urgent:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.is_urgent ? "Yes" : "No" %>
              </span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Measurement Dress Given:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.measurement_dress_given ? "Yes" : "No" %>
              </span>
            </p>
          </div>
        </div>
        <hr class="horizontal dark my-3">
        <!-- ASSIGNMENT & DATES -->
        <h6 class="text-uppercase text-dark mb-3">Assignment & Dates</h6>
        <div class="row mb-3">
          <div class="col-md-6">
            <p class="text-sm mb-2 text-dark">
              <strong>Assigned Worker:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.worker&.name || "-" %>
              </span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Delivery Date:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.delivery_date || "-" %>
              </span>
            </p>
          </div>
          <div class="col-md-6">
            <p class="text-sm mb-2 text-dark">
              <strong>Trial Date:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.trial_date || "-" %>
              </span>
            </p>
            <p class="text-sm mb-2 text-dark">
              <strong>Completion Date:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.completion_date || "-" %>
              </span>
            </p>
          </div>
        </div>
        <hr class="horizontal dark my-3">
        <!-- EXTRA INFO -->
        <h6 class="text-uppercase text-dark mb-3">Additional Information</h6>
        <div class="row mb-3">
          <div class="col-md-6">
            <p class="text-sm mb-2 text-dark">
              <strong>Special Instruction:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.special_instruction.presence || "-" %>
              </span>
            </p>
          </div>
          <div class="col-md-6">
            <p class="text-sm mb-2 text-dark">
              <strong>Video Link:</strong>
              <span class="text-dark ms-2">
                <%= @order_item.video_link.presence || "-" %>
              </span>
            </p>
          </div>
        </div>
        <hr class="horizontal dark my-3">
        <%= render "order_item_measurements",
      order_measurements: @order_measurements %>
        <!-- BACK -->
        <%= link_to admin_order_path(@order_item.order),
              class: "btn btn-secondary btn-sm text-uppercase font-weight-bold float-end mt-3",
              data: { turbo_frame: "_top" } do %>
          Back
        <% end %>
      </div>
    </div>
  </div>
</div>
