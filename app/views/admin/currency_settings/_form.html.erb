<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="card my-4">
        <!-- HEADER (same pattern as User Edit) -->
        <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
          <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
            <h6 class="text-white text-capitalize ps-3 mb-0">
              <%= @currency_setting.persisted? ? "Edit Currency Setting" : "Add Currency Setting" %>
            </h6>
          </div>
        </div>

        <!-- BODY -->
        <div class="card-body px-4 pb-4">
          <%= form_with model: [:admin, @currency_setting], local: true do |f| %>
            <div class="row g-4">
              <!-- Country -->
              <div class="col-md-4">
                <label class="form-label font-weight-bold text-dark">Country</label>
                <div class="input-group input-group-outline">
                  <%= f.select :country,
                        CurrencySetting::SUPPORTED_CURRENCIES.keys,
                        { prompt: "Select Country" },
                        class: "form-control" %>
                </div>
              </div>

              <!-- Currency -->
              <div class="col-md-4">
                <label class="form-label font-weight-bold text-dark">Currency</label>
                <div class="input-group input-group-outline">
                  <%= f.select :currency_code,
                        CurrencySetting::SUPPORTED_CURRENCIES.values,
                        { prompt: "Select Currency" },
                        class: "form-control" %>
                </div>
              </div>

              <!-- Amount Limit -->
              <div class="col-md-4">
                <label class="form-label font-weight-bold text-dark">Amount Limit</label>
                <div class="input-group input-group-outline">
                  <%= f.number_field :amount_limit,
                        step: 0.01,
                        class: "form-control",
                        placeholder: "Enter amount limit" %>
                </div>
              </div>
            </div>

            <!-- ACTIONS -->
            <div class="d-flex justify-content-end mt-4">
              <%= link_to "Back",
                    admin_currency_settings_path,
                    class: "btn btn-secondary me-2 text-uppercase font-weight-bold" %>

              <%= f.submit(
                            @currency_setting.persisted? ? "Update" : "Save",
                            class: "btn btn-info text-white text-uppercase font-weight-bold"
                          ) %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
