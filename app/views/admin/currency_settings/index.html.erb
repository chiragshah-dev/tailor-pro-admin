<div class="container-fluid py-2">
  <div class="card my-4">
    <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
      <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3 d-flex justify-content-between">
        <h6 class="text-white ps-3 mb-0">Currency Settings</h6>
        <%= link_to "Add New", new_admin_currency_setting_path,
          class: "btn btn-sm btn-white text-dark me-3 text-uppercase font-weight-bold" %>
      </div>
    </div>

    <div class="card-body px-0 pb-2">
      <div class="table-responsive p-0">
        <table class="table align-items-center mb-0">
          <thead>
            <tr>
              <th>Country</th>
              <th>Currency</th>
              <th>Amount Limit</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @currency_settings.each do |setting| %>
              <tr>
                <td><strong><%= setting.country %></strong></td>
                <td><%= setting.currency_code %></td>
                <td><%= number_to_currency(setting.amount_limit, unit: setting.currency_code + " ") %></td>
                <td class="text-center">
                  <%= link_to edit_admin_currency_setting_path(setting), class: "btn btn-xs btn-secondary" do %>
                    <i class="fas fa-edit"></i>
                  <% end %>
                  <%= button_to admin_currency_setting_path(setting),
                        method: :delete,
                        class: "btn btn-xs btn-secondary",
                        form: { class: "d-inline" },
                        data: { confirm: "Are you sure?" } do %>
                    <i class="fas fa-trash"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
