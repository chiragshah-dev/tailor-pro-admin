<main class="main-content" style="overflow: hidden; height: 100vh; position: relative; width: 100vw;" id="login-page">
  <div class="tailor-reveal-wrapper" id="revealWrapper" style="display: none;">
    <div class="scissors-tool" id="scissors">
      <svg width="80" height="80" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g class="scissor-part handle-bottom">
          <circle cx="20" cy="70" r="10" stroke="white" stroke-width="4"/>
          <path d="M30 65 L90 52" stroke="white" stroke-width="5" stroke-linecap="round"/>
        </g>
        <g class="scissor-part handle-top">
          <circle cx="20" cy="30" r="10" stroke="white" stroke-width="4"/>
          <path d="M30 35 L90 48" stroke="white" stroke-width="5" stroke-linecap="round"/>
        </g>
        <circle cx="42" cy="50" r="2.5" fill="white"/>
      </svg>
    </div>
    
    <div class="fabric fabric-top"></div>
    <div class="fabric fabric-bottom"></div>
  </div>
  <div class="login-viewport-center" id="viewportCenter">
    <div class="login-card fade-in-up" id="loginCard">
      <div class="card-header text-center bg-transparent border-0 pt-4 pb-0">
        <h6 class="logo-text">TAILOR<span class="fw-bold">PRO</span></h6>
        <div class="divider-small"></div>
        <% if flash[:alert] && flash[:alert] != 'You need to sign in or sign up before continuing.' %>
          <div class="alert-error-bespoke" id="errorPresence">
            <%= flash[:alert]  %>
          </div>
        <% end %>
      </div>
      <div class="card-body px-5 pb-4 pt-2">
        <%= form_with scope: :admin_user, url: admin_user_session_path, local: true do |f| %>
          <div class="mb-3">
            <label class="label-tiny">IDENTIFICATION</label>
            <%= f.email_field :email, class: "input-bespoke", placeholder: "Email address", required: true %>
          </div>
          <div class="mb-4">
            <label class="label-tiny">PASSCODE</label>
            <div class="password-wrapper">
              <%= f.password_field :password, class: "input-bespoke", id: "admin_password", placeholder: "••••••••", required: true %>
              <button type="button" class="password-toggle" id="togglePassword">
                <i class="fas fa-eye" id="eyeIcon"></i>
              </button>
            </div>
          </div>
          <button type="submit" class="btn-submit-slim">
            PROCEED
          </button>
        <% end %>
      </div>
    </div>
  </div>
</main>

