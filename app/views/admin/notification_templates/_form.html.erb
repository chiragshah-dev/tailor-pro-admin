<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
          <h6 class="text-white text-capitalize ps-3 mb-0">
            <%= @template.new_record? ? "Add Notification Template" : "Edit Notification Template" %>
          </h6>
        </div>
      </div>
      <!-- BODY -->
      <div class="card-body px-4 pb-4">
        <%= form_with model: [:admin, @template], local: true do |f| %>
          <%= hidden_field_tag :page, params[:page] %>
          <div class="row g-4">
            <!-- KEY -->
            <div class="form-group col-md-6">
              <label class="form-label font-weight-bold text-dark">
                Key
              </label>
              <div class="input-group input-group-outline">
                <%= f.text_field :key,
      class: "form-control",
      readonly: @template.persisted? %>
              </div>
              <div id="key_err" class="text-danger mt-2 text-xs">
                <%= @template.errors.full_messages_for(:key).first %>
              </div>
            </div>
            <!-- STATUS -->
            <div class="form-group col-md-6">
              <label class="form-label font-weight-bold text-dark">
                Active
              </label>
              <div class="input-group input-group-outline">
                <%= f.select :active,
                      [["Yes", true], ["No", false]],
                      {},
                      class: "form-control" %>
              </div>
            </div>
            <!-- TITLE -->
            <div class="form-group col-md-12">
              <label class="form-label font-weight-bold text-dark">
                Title
              </label>
              <div class="input-group input-group-outline">
                <%= f.text_field :title, class: "form-control" %>
              </div>
              <div id="title_err" class="text-danger mt-2 text-xs">
                <%= @template.errors.full_messages_for(:title).first %>
              </div>
            </div>
            <!-- BODY -->
            <div class="form-group col-md-12">
              <label class="form-label font-weight-bold text-dark">
                Body
              </label>
              <div class="input-group input-group-outline">
                <%= f.text_area :body, rows: 4, class: "form-control" %>
              </div>
              <div id="body_err" class="text-danger mt-2 text-xs">
                <%= @template.errors.full_messages_for(:body).first %>
              </div>
            </div>
          </div>
          <!-- ACTIONS -->
          <div class="d-flex justify-content-end mt-4">
            <%= link_to "Back",
                  admin_notification_templates_path,
                  class: "btn btn-secondary me-2 text-uppercase font-weight-bold" %>
            <%= f.submit (@template.new_record? ? "Create" : "Update"),
                  class: "btn btn-info text-white text-uppercase font-weight-bold" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
<script>
  document.addEventListener("turbo:load", () => {


    const form = document.querySelector("form");
    if (!form) return;

    const keyInput   = document.getElementById("notification_template_key");
    const titleInput = document.getElementById("notification_template_title");
    const bodyInput  = document.getElementById("notification_template_body");

    const keyErr   = document.getElementById("key_err");
    const titleErr = document.getElementById("title_err");
    const bodyErr  = document.getElementById("body_err");

    form.addEventListener("submit", function(e){
      let valid = true;

      keyErr.innerHTML = "";
      titleErr.innerHTML = "";
      bodyErr.innerHTML = "";

      if(!keyInput.value.trim()){
        keyErr.innerHTML = "Key can't be blank";
        keyInput.classList.add("is-invalid");
        valid = false;
      }

      if(!titleInput.value.trim()){
        titleErr.innerHTML = "Title can't be blank";
        titleInput.classList.add("is-invalid");
        valid = false;
      }

      if(!bodyInput.value.trim()){
        bodyErr.innerHTML = "Body can't be blank";
        bodyInput.classList.add("is-invalid");
        valid = false;
      }

      if(!valid) e.preventDefault();
    });

    keyInput?.addEventListener("input", () => {
      keyInput.value = keyInput.value.replace(/[^a-zA-Z0-9_]/g, "");
      keyErr.innerHTML = "";
      keyInput.classList.remove("is-invalid");
    });

    titleInput?.addEventListener("input", () => {
      titleErr.innerHTML = "";
      titleInput.classList.remove("is-invalid");
    });

    bodyInput?.addEventListener("input", () => {
      bodyErr.innerHTML = "";
      bodyInput.classList.remove("is-invalid");
    });

  });
</script>
