  
<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
          <h6 class="text-white text-capitalize ps-3 mb-0">
            <%= @currency.persisted? ? "Edit Currency" : "New Currency" %>            </h6>
        </div>
      </div>
      <!-- BODY -->
      <div class="card-body px-4 pb-4">
        <%= form_with model: [:admin, @currency], local: true do |f| %>
          <%= hidden_field_tag :page, params[:page] %>
          <div class="row g-4">
            <!-- Name -->
            <div class="col-md-6">
              <label class="form-label font-weight-bold text-dark">Currency Name</label>
              <div class="input-group input-group-outline">
                <%= f.text_field :name, class: "form-control" %>
              </div>
              <div id="name_err" class="text-danger mt-2 text-xs">
                <%= @currency.errors.full_messages_for(:name).first %>
              </div>
            </div>
          </div>
          <!-- ACTIONS -->
          <div class="d-flex justify-content-end mt-4">
            <%= link_to "Back",
                    admin_currencies_path(page: params[:page]),
                    class: "btn btn-secondary me-2 text-uppercase font-weight-bold" %>
            <%= f.submit @currency.persisted? ? "Update" : "Create",
                    class: "btn btn-info text-white text-uppercase font-weight-bold" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
<script>
  document.addEventListener("turbo:render", () => {
    const form = document.querySelector("form");
    if (!form) return;

    const currencyField = document.getElementById("currency_name");
    const errorDiv = document.getElementById("name_err");

    const currencyRegex = /^[A-Z]{3}$/;

    form.addEventListener("submit", (e) => {
      let valid = true;
      errorDiv.innerHTML = "";
      currencyField.classList.remove("is-invalid");

      if (!currencyField.value.trim()) {
        errorDiv.innerHTML = "Currency code can't be empty";
        currencyField.classList.add("is-invalid");
        valid = false;
      } else if (!currencyRegex.test(currencyField.value.trim())) {
        errorDiv.innerHTML = "Currency code must be 3 uppercase letters (e.g. USD, INR)";
        currencyField.classList.add("is-invalid");
        valid = false;
      }

      if (!valid) e.preventDefault();
    });

    currencyField.addEventListener("input", () => {
      errorDiv.innerHTML = "";
      currencyField.classList.remove("is-invalid");
    });
  });
</script>
