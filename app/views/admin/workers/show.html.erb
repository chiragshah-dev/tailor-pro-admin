<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="card mb-4">
        <!-- HEADER -->
        <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
          <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3 d-flex justify-content-between align-items-center">
            <h6 class="text-white text-capitalize ps-3 mb-0">
              Worker Details
            </h6>
            <div class="me-3 d-flex gap-2">
              <%= link_to edit_admin_worker_path(@worker),
                  class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold" do %>
                Edit
              <% end %>
              <%= button_to admin_worker_path(@worker, page: params[:page]),
              method: :delete,
              class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold",
              data: { turbo_confirm: "Are you sure you want to delete #{@worker.name}?" } do %>
                Delete
              <% end %>
            </div>
          </div>
        </div>
        <div class="card-body px-4 pt-4 pb-2">
          <div class="row">
            <div class="col-md-6">
              <p class="text-sm mb-2">
                <span class="fw-bold text-dark">Name:</span>
                <span class="text-sm text-secondary mb-0 font-weight-bold ms-2">
                  <%= @worker.name %>
                </span>
              </p>
              <p class="text-sm mb-2">
                <span class="fw-bold text-dark">Contact Number:</span>
                <span class="text-sm text-secondary mb-0 font-weight-bold ms-2">
                  <%= @worker.contact_number.presence || "-" %>
                </span>
              </p>
              <p class="text-sm mb-2">
                <span class="fw-bold text-dark">Job Role:</span>
                <span class="text-sm text-secondary mb-0 font-weight-bold ms-2">
                  <%= @worker.job_role&.name || "-" %>
                </span>
              </p>
            </div>
            <div class="col-md-6">
              <p class="text-sm mb-2">
                <span class="fw-bold text-dark">Store:</span>
                <span class="text-sm text-secondary mb-0 font-weight-bold ms-2">
                  <% if @worker.store.present? %>
                    <%= link_to @worker.store.name,
                        admin_store_path(@worker.store),
                        class: "text-decoration-none text-dark fw-bold" %>
                  <% else %>
                    —
                  <% end %>
                </span>
              </p>
            </div>
          </div>
          <hr class="horizontal dark my-4">
          <div class="d-flex justify-content-end">
            <%= link_to admin_workers_path(page: @current_page, search: @search),
                class: "btn btn-secondary btn-sm text-uppercase font-weight-bold" do %>
              Back
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
