  
<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
          <h6 class="text-white text-capitalize ps-3 mb-0">
            Edit Worker
          </h6>
        </div>
      </div>
      <!-- BODY -->
      <div class="card-body px-4 pb-4">
        <%= form_with model: [:admin, @worker], local: true do |f| %>
          <%= hidden_field_tag :page, params[:page] %>
          <div class="row g-4">
            <!-- Name -->
            <div class="form-group col-md-6">
              <label class="form-label font-weight-bold text-dark">Full Name</label>
              <div class="input-group input-group-outline">
                <%= f.text_field :name, class: "form-control" %>
              </div>
              <div id="name_err" class="text-danger mt-2 text-xs "><%= @worker.errors.full_messages_for(:name).first %> </div>
            </div>
            <!-- Contact -->
            <div class="form-group col-md-6">
              <label class="form-label font-weight-bold text-dark">
                Contact Number
              </label>
              <div class="input-group input-group-outline">
                <%= f.number_field :contact_number, class: "form-control" %>
              </div>
              <div id="contat_err" class="text-danger mt-2 text-xs "><%= @worker.errors.full_messages_for(:contact_number).first %> </div>
            </div>
            <!-- Job Role -->
            <div class="form-group col-md-6">
              <label class="form-label font-weight-bold text-dark">
                Job Role
              </label>
              <div class="input-group input-group-outline">
                <%= f.collection_select :job_role_id,
                        JobRole.all,
                        :id,
                        :name,
                        { prompt: "Select Role" },
                        class: "form-control" %>
              </div>
              <div id="job_role_err" class="text-danger mt-2 text-xs "><%= @worker.errors.full_messages_for(:job_role_id).first %> </div>
            </div>
          </div>
          <!-- ACTIONS -->
          <div class="d-flex justify-content-end mt-4">
            <%= link_to "Back",
                    admin_workers_path(page: params[:page]),
                    class: "btn btn-secondary me-2 text-uppercase font-weight-bold" %>
            <%= f.submit "Update",
                    class: "btn btn-info text-white text-uppercase font-weight-bold" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
<script>
  document.addEventListener("turbo:load", () => {

    const form = document.querySelector("form");
    if (!form) return;

    const nameInput  = document.getElementById("worker_name");
    const phoneInput = document.getElementById("worker_contact_number");
    const roleInput  = document.getElementById("worker_job_role_id");

    const nameErr  = document.getElementById("name_err");
    const phoneErr = document.getElementById("contat_err");
    const roleErr  = document.getElementById("job_role_err");

    form.addEventListener("submit", function (e) {
      let valid = true;

      // reset errors
      nameErr.innerHTML  = "";
      phoneErr.innerHTML = "";
      roleErr.innerHTML  = "";

      // Name
      if (!nameInput.value.trim()) {
        nameErr.innerHTML = "Name can't be blank";
          nameInput.classList.add("is-invalid");

        valid = false;
      }

      // Phone Validation
      const phone = phoneInput.value.trim();
      const phoneRegex = /^[6-9]\d{9}$/;   // India 10-digit strict

      if (!phone) {
        phoneErr.innerHTML = "Contact number can't be blank";
          phoneInput.classList.add("is-invalid");

        valid = false;
      } else if (!phoneRegex.test(phone)) {
        phoneErr.innerHTML = "Enter valid 10 digit mobile number";
          phoneInput.classList.add("is-invalid");

        valid = false;
      }

      // Role
      if (!roleInput.value) {
        roleErr.innerHTML = "Job role is required";
          roleInput.classList.add("is-invalid");

        valid = false;
      }

      if (!valid) e.preventDefault();
    });



   // NAME clear err when type
  nameInput?.addEventListener("input", () => {
  const v = nameInput.value.trim();
  if (v.length > 0) nameErr.innerHTML = "";
      nameInput.classList.remove("is-invalid");

  });

  // PHONE clear err when type
  phoneInput?.addEventListener("input", () => {
  const v = String(phoneInput.value).trim();
  if (v.length > 0) phoneErr.innerHTML = "";
      phoneInput.classList.remove("is-invalid");

  });

  // ROLE clear err when type
  roleInput?.addEventListener("change", () => {
  if (roleInput.value) roleErr.innerHTML = "";
      roleInput.classList.remove("is-invalid");

  });



  });
</script>