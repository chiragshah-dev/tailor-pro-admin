<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- PAGE HEADER -->
      <div class="row">
        <div class="col-12">
          <div class="card">
            <!-- PAGE HEADER -->
            <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
              <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3 d-flex justify-content-between align-items-center">
                <h6 class="text-white text-capitalize ps-3 mb-0">
                  Store Details
                </h6>
                <div class="me-3 d-flex gap-2">
                  <%= link_to admin_store_measurement_fields_path(store_id: @store.id),
              class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold" do %>
                    Store Measurements
                  <% end %>
                  <%= link_to edit_admin_store_path(@store,page: params[:page]),
              class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold" do %>
                    Edit
                  <% end %>
                  <%#= button_to admin_store_path(@store, page: params[:page]),
              method: :delete,
              class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold",
              data: { turbo_confirm: "Are you sure you want to delete #{@store.name}?" } do %>
                    <%# Delete %>
                    <%# end %>
                  </div>
                </div>
              </div>
              <!-- STORE BODY -->
              <div class="card-body px-4 pt-4 pb-4">
                <!-- BASIC INFO -->
                <div class="row mb-3">
                  <div class="col-md-6">
                    <p class="text-sm mb-2 text-dark">
                      <strong>Store Name:</strong>
                      <span class="ms-2"><%= @store.name %></span>
                    </p>
                    <% if @store.code.present? %>
                      <p class="text-sm mb-2 text-dark">
                        <strong>Store Code:</strong>
                        <span class="ms-2"><%= @store.code %></span>
                      </p>
                    <% end %>
                    <p class="text-sm mb-2 text-dark">
                      <strong>Store Type:</strong>
                      <span class="ms-2 text-capitalize"><%= @store.store_type %></span>
                    </p>
                    <% if @store.stitches_for.present? %>
                      <p class="text-sm mb-2 text-dark">
                        <strong>Stitches For:</strong>
                        <span class="ms-2 text-capitalize"><%= @store.stitches_for %></span>
                      </p>
                    <% end %>
                    <p class="text-sm mb-2 text-dark">
                      <strong>Main Store:</strong>
                      <span class="ms-2">
                        <% if @store.is_main_store %>
                          <span class="badge bg-gradient-success">YES</span>
                        <% else %>
                          <span class="badge bg-gradient-secondary">NO</span>
                        <% end %>
                      </span>
                    </p>
                  </div>
                  <div class="col-md-6">
                    <p class="text-sm mb-2 text-dark">
                      <strong>Contact Number:</strong>
                      <span class="ms-2"><%= @store.contact_number.presence || "-" %></span>
                    </p>
                    <% if @store.email.present? %>
                      <p class="text-sm mb-2 text-dark">
                        <strong>Email:</strong>
                        <span class="ms-2"><%= @store.email %></span>
                      </p>
                    <% end %>
                    <% if @store.website_url.present? %>
                      <p class="text-sm mb-2 text-dark">
                        <strong>Website:</strong>
                        <span class="ms-2"><%= @store.website_url %></span>
                      </p>
                    <% end %>
                    <p class="text-sm mb-2 text-dark">
                      <strong>Owner:</strong>
                      <span class="ms-2"><%= @store.user&.name || "-" %></span>
                    </p>
                    <p class="text-sm mb-2 text-dark">
                      <strong>Created At:</strong>
                      <% tz = @store.user&.timezone || Time.zone %>
                      <span class="ms-2">
                        <%= @store.created_at.in_time_zone(tz).strftime("%d %b %Y %I:%M %p") %>
                      </span>
                    </p>
                  </div>
                </div>
                <!-- LOCATION -->
                <% if @store.location_name.present? || @store.address.present? ||
          @store.city.present? || @store.state.present? ||
          @store.country.present? || @store.postal_code.present? %>
                <hr class="horizontal dark my-3" style="border-top: 1.5px solid #adb5bd; opacity: 1; margin: 12px 0;">
                <h6 class="text-uppercase text-dark mb-3 d-flex justify-content-between align-items-center"
    data-bs-toggle="collapse"
    data-bs-target="#locationCollapse"
    style="cursor:pointer;font-weight:600;">
                  Location Details
                  <i class="fas fa-chevron-down text-dark"></i>
                </h6>
                <div id="locationCollapse" class="collapse">
                  <div class="row mb-3">
                    <% if @store.location_name.present? || @store.address.present? %>
                      <div class="col-md-6">
                        <% if @store.location_name.present? %>
                          <p class="text-sm mb-2 text-dark">
                            <strong>Location Name:</strong>
                            <span class="ms-2"><%= @store.location_name %></span>
                          </p>
                        <% end %>
                        <% if @store.address.present? %>
                          <p class="text-sm mb-2 text-dark">
                            <strong>Address:</strong>
                            <span class="ms-2"><%= @store.address %></span>
                          </p>
                        <% end %>
                      </div>
                    <% end %>
                    <% if @store.city.present? || @store.state.present? ||
                @store.country.present? || @store.postal_code.present? %>
                    <div class="col-md-6">
                      <% if @store.city.present? || @store.state.present? %>
                        <p class="text-sm mb-2 text-dark">
                          <strong>City / State:</strong>
                          <span class="ms-2">
                            <%= [@store.city, @store.state].compact.join(", ") %>
                          </span>
                        </p>
                      <% end %>
                      <% if @store.country.present? || @store.postal_code.present? %>
                        <p class="text-sm mb-2 text-dark">
                          <strong>Country / Postal Code:</strong>
                          <span class="ms-2">
                            <%= [@store.country, @store.postal_code].compact.join(" - ") %>
                          </span>
                        </p>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
            <!-- GST -->
            <% if @store.gst_number.present? || @store.gst_name.present? ||
          @store.gst_percentage.present? || !@store.gst_included_on_bill.nil? %>
            <hr class="horizontal dark my-3" style="border-top: 1.5px solid #adb5bd; opacity: 1; margin: 12px 0;">
            <h6 class="text-uppercase text-dark mb-3 d-flex justify-content-between align-items-center"
    data-bs-toggle="collapse"
    data-bs-target="#gstCollapse"
    style="cursor:pointer;font-weight:600;">
              GST Details
              <i class="fas fa-chevron-down text-dark"></i>
            </h6>
            <div id="gstCollapse" class="collapse">
              <div class="row mb-3">
                <% if @store.gst_number.present? || @store.gst_name.present? %>
                  <div class="col-md-6">
                    <% if @store.gst_number.present? %>
                      <p class="text-sm mb-2 text-dark">
                        <strong>GST Number:</strong>
                        <span class="ms-2"><%= @store.gst_number %></span>
                      </p>
                    <% end %>
                    <% if @store.gst_name.present? %>
                      <p class="text-sm mb-2 text-dark">
                        <strong>GST Name:</strong>
                        <span class="ms-2"><%= @store.gst_name %></span>
                      </p>
                    <% end %>
                  </div>
                <% end %>
                <% if @store.gst_percentage.present? || !@store.gst_included_on_bill.nil? %>
                  <div class="col-md-6">
                    <% unless @store.gst_included_on_bill.nil? %>
                      <p class="text-sm mb-2 text-dark">
                        <strong>GST Included:</strong>
                        <span class="ms-2"><%= @store.gst_included_on_bill ? "Yes" : "No" %></span>
                      </p>
                    <% end %>
                    <% if @store.gst_percentage.present? %>
                      <p class="text-sm mb-2 text-dark">
                        <strong>GST Percentage:</strong>
                        <span class="ms-2"><%= @store.gst_percentage %>%</span>
                      </p>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
          <!-- BANK -->
          <% bank = @store.store_bank_detail %>
          <% if bank.present? &&
          (bank.account_holder_name.present? || bank.bank_name.present? ||
           bank.account_number.present? || bank.ifsc_code.present? ||
           bank.upi_id.present? || bank.qr_code.attached? || !bank.verified.nil?) %>
          <hr class="horizontal dark my-3" style="border-top: 1.5px solid #adb5bd; opacity: 1; margin: 12px 0;">
          <h6 class="text-uppercase text-dark mb-3 d-flex justify-content-between align-items-center"
    data-bs-toggle="collapse"
    data-bs-target="#bankCollapse"
    style="cursor:pointer;font-weight:600;">
            Bank Details
            <i class="fas fa-chevron-down text-dark"></i>
          </h6>
          <div id="bankCollapse" class="collapse">
            <div class="row mb-3">
              <% if bank.account_holder_name.present? || bank.bank_name.present? ||
                bank.account_number.present? || bank.qr_code.attached? %>
              <div class="col-md-6">
                <% if bank.account_holder_name.present? %>
                  <p class="text-sm mb-2 text-dark">
                    <strong>Account Holder Name:</strong>
                    <span class="ms-2"><%= bank.account_holder_name %></span>
                  </p>
                <% end %>
                <% if bank.bank_name.present? %>
                  <p class="text-sm mb-2 text-dark">
                    <strong>Bank Name:</strong>
                    <span class="ms-2"><%= bank.bank_name %></span>
                  </p>
                <% end %>
                <% if bank.account_number.present? %>
                  <p class="text-sm mb-2 text-dark">
                    <strong>Account Number:</strong>
                    <span class="ms-2"><%= bank.account_number %></span>
                  </p>
                <% end %>
                <% if bank.qr_code.attached? %>
                  <p class="text-sm mb-2 text-dark"><strong>QR Code:</strong></p>
                  <div class="mb-3">
                    <%= image_tag bank.qr_code, class:"img-thumbnail", style:"max-width:180px;" %>
                  </div>
                <% end %>
              </div>
            <% end %>
            <% if bank.ifsc_code.present? || bank.upi_id.present? || !bank.verified.nil? %>
              <div class="col-md-6">
                <% if bank.ifsc_code.present? %>
                  <p class="text-sm mb-2 text-dark">
                    <strong>IFSC Code:</strong>
                    <span class="ms-2"><%= bank.ifsc_code %></span>
                  </p>
                <% end %>
                <% if bank.upi_id.present? %>
                  <p class="text-sm mb-2 text-dark">
                    <strong>UPI ID:</strong>
                    <span class="ms-2"><%= bank.upi_id %></span>
                  </p>
                <% end %>
                <% unless bank.verified.nil? %>
                  <p class="text-sm mb-2 text-dark">
                    <strong>Verified:</strong>
                    <span class="ms-2">
                      <% if bank.verified %>
                        <span class="badge bg-gradient-success">Verified</span>
                      <% else %>
                        <span class="badge bg-gradient-secondary">Not Verified</span>
                      <% end %>
                    </span>
                  </p>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      <%= render 'orders' %>
      <%= render 'worker' %>
      <%= link_to admin_stores_path(page: params[:page]),
          class:"btn btn-secondary btn-sm text-uppercase font-weight-bold float-end mt-3" do %>
        Back
      <% end %>
    </div>
  </div>
</div>
</div>
