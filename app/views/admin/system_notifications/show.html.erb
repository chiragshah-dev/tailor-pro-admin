<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3 d-flex justify-content-between align-items-center">
          <h6 class="text-white text-capitalize ps-3 mb-0">
            System Notification
          </h6>
          <div class="me-3 d-flex gap-2">
            <%= link_to edit_admin_system_notification_path(@system_notification, page: params[:page]),
                  class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold" do %>
              Edit
            <% end %>
            <%#= button_to admin_system_notification_path(@system_notification, page: params[:page]),
                  method: :delete,
                  class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold",
                  data: { turbo_confirm: "Are you sure you want to delete #{@system_notification.title}?" } do %>
              <%# Delete %>
              <%# end %>
            </div>
          </div>
        </div>
        <!-- BODY -->
        <div class="card-body px-4 pt-4 pb-2">
          <div class="row">
            <div class="col-md-6">
              <p class="text-sm mb-2">
                <span class="fw-bold text-dark">Title:</span>
                <span class="text-sm text-dark mb-0  ms-2">
                  <%= @system_notification.title %>
                </span>
              </p>
              <p class="text-sm mb-2">
                <span class="fw-bold text-dark">Active:</span>
                <span class="text-sm text-dark mb-0  ms-2">
                  <%= @system_notification.is_active ? "Yes" : "No" %>
                </span>
              </p>
              <p class="text-sm mb-2">
                <span class="fw-bold text-dark">Body:</span>
                <span class="text-sm text-dark mb-0  ms-2">
                  <%= @system_notification.message %>
                </span>
              </p>
            </div>
          </div>
          <!-- ACTIONS -->
          <div class="d-flex justify-content-end">
            <%= link_to admin_system_notifications_path(page: params[:page]),
                class: "btn btn-secondary btn-sm text-uppercase font-weight-bold" do %>
              Back
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
