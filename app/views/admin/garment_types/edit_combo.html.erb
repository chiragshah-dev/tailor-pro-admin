<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
          <h6 class="text-white ps-3 mb-0">
            Edit Combo Garment
          </h6>
        </div>
      </div>
      <!-- BODY -->
      <div class="card-body px-4 pb-4">
        <%= form_with model: [:admin, @garment_type],
              url: update_combo_admin_garment_type_path(@garment_type),
              method: :patch,
              local: true do |f| %>
          <div class="row g-4">
            <!-- COMBO NAME -->
            <div class="form-group col-md-6">
              <label class="form-label font-weight-bold text-dark">
                Combo Name
              </label>
              <div class="input-group input-group-outline">
                <%= f.text_field :garment_name,
                      class: "form-control",
                      placeholder: "Enter combo name" %>
              </div>
            </div>
            <!-- GENDER -->
            <div class="form-group col-md-6">
              <label class="form-label font-weight-bold text-dark">
                Gender
              </label>
              <div class="input-group input-group-outline">
                <%= f.select :gender,
                      GarmentType.genders.except(:both).keys.map { |g| [g.titleize, g] },
                      { prompt: "Select Gender" },
                      class: "form-control",
                      id: "combo_gender" %>
              </div>
            </div>
            <!-- ACTIVE -->
            <div class="form-group col-md-6">
              <label class="form-label font-weight-bold text-dark">
                Active
              </label>
              <div class="input-group input-group-outline">
                <%= f.select :active,
                      [["Yes", true], ["No", false]],
                      {},
                      class: "form-control" %>
              </div>
            </div>
          </div>
          <hr class="my-4">
          <!-- GARMENTS -->
          <h6 class="text-uppercase text-dark mb-3">
            Select Garments for Combo
          </h6>
          <div class="row">
            <% @single_garments.each do |garment| %>
              <div class="col-md-4 mb-2 garment-option"
                   data-gender="<%= garment.gender %>">
                <div class="form-check">
                  <%= check_box_tag "child_ids[]",
                        garment.id,
                        @garment_type.combo_items.ids.include?(garment.id),
                        id: "child_#{garment.id}",
                        class: "form-check-input" %>
                  <%= label_tag "child_#{garment.id}",
                        garment.garment_name,
                        class: "form-check-label" %>
                </div>
              </div>
            <% end %>
          </div>
          <hr class="my-4">
          <!-- IMAGE -->
          <div class="form-group col-md-6">
            <label class="form-label font-weight-bold text-dark">
              Combo Image
            </label>
            <% if f.object.image.attached? %>
              <div class="mb-2">
                <%= image_tag f.object.image,
                      class: "img-thumbnail",
                      style: "max-width: 150px;" %>
              </div>
            <% end %>
            <div class="d-flex align-items-center gap-2">
              <label class="btn bg-gradient-info text-white mb-0">
                Choose Image
                <%= f.file_field :image,
                      class: "d-none",
                      accept: "image/png,image/jpeg",
                      onchange: "this.closest('.d-flex').querySelector('.file-name').innerText = this.files[0]?.name || 'No file chosen'" %>
              </label>
              <span class="file-name text-muted">
                No file chosen
              </span>
            </div>
          </div>
          <!-- ACTIONS -->
          <div class="d-flex justify-content-end mt-4">
            <%= link_to "Back",
                  admin_garment_types_path,
                  class: "btn btn-secondary me-2 text-uppercase font-weight-bold" %>
            <%= f.submit "Update Combo",
                  class: "btn btn-info text-white text-uppercase font-weight-bold" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
<script>
  document.addEventListener("turbo:load", function () {

   const genderSelect = document.getElementById("combo_gender");
   const garments = document.querySelectorAll(".garment-option");

   if (!genderSelect) return;

   function filterGarments() {

     const selectedGender = genderSelect.value;

     garments.forEach(item => {

       const garmentGender = item.dataset.gender;
       const checkbox = item.querySelector("input");

       if (!selectedGender) {
         item.style.display = "none";
         return;
       }

       // ✅ SHOW if gender matches
       if (garmentGender === selectedGender) {
         item.style.display = "block";
       } else {

         // ✅ IMPORTANT: hide ONLY — DO NOT uncheck
         item.style.display = "none";

         // ❌ REMOVE THIS (BIG BUG)
         // checkbox.checked = false;
       }

     });
   }

   genderSelect.addEventListener("change", filterGarments);

   // run on load
   filterGarments();

  });
</script>
