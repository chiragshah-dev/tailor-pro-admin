<%= form_with url: url, method: :get, local: true do %>
  <div class="d-flex justify-content-end flex-wrap align-items-center gap-2">

    <!-- FILTERS FIRST -->
    <%= yield if block_given? %>

    <!-- SEARCH INPUT (always at the end) -->
    <div>
      <div class="input-group input-group-outline">
        <%= text_field_tag :search, params[:search],
              class: "form-control",
              placeholder: placeholder || "Search..." %>
      </div>
    </div>

    <!-- ACTION BUTTONS -->
    <%= submit_tag "Search",
          class: "btn bg-gradient-info px-4 mb-0 font-weight-bold text-uppercase" %>

    <% if params[:search].present? || params[:store_type].present? %>
      <%= link_to "Reset",
            url,
            class: "btn btn-secondary px-4 mb-0 font-weight-bold text-uppercase" %>
    <% end %>

  </div>
<% end %>
