<nav class="navbar navbar-main navbar-expand-lg bg-white px-4 py-1 shadow-sm border-radius-xl mt-2 pt-2 custom-navbar m-auto" style="width: 97%;">
  <div class="container-fluid d-flex align-items-center justify-content-between">
    <%# ================= LEFT : Breadcrumb ================= %>
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent mb-1 p-0">
          <% dynamic_breadcrumbs.each_with_index do |crumb, i| %>
            <% last = i == dynamic_breadcrumbs.size - 1 %>
            <li class="breadcrumb-item text-sm <%= 'text-dark active' if last %>">
              <% if last || crumb[:path].blank? %>
                <span><%= crumb[:label] %></span>
              <% else %>
                <%= link_to crumb[:label], crumb[:path], class: "text-muted" %>
              <% end %>
            </li>
          <% end %>
        </ol>
      </nav>
    </div>
    <%# ================= RIGHT : Profile ================= %>
    <% is_super_admin = current_admin_user&.role&.is_super_admin? %>
    <ul class="navbar-nav">
      <li class="nav-item d-xl-none ps-3 d-flex align-items-center">
        <a href="javascript:;" class="nav-link text-body p-0" id="iconNavbarSidenav">
          <div class="sidenav-toggler-inner">
            <i class="sidenav-toggler-line"></i>
            <i class="sidenav-toggler-line"></i>
            <i class="sidenav-toggler-line"></i>
          </div>
        </a>
      </li>
      <li class="nav-item dropdown">
        <a class="nav-link d-flex align-items-center gap-2 px-3 py-2 rounded"
           href="#"
           id="profileDropdown"
           role="button"
           data-bs-toggle="dropdown"
           aria-expanded="false">
          <%# Icon based on privilege %>
          <% icon = is_super_admin ? "shield" : "admin_panel_settings" %>
          <i class="material-symbols-rounded fs-4"><%= icon %></i>
          <span class="text-sm">
            <%= current_admin_user&.email&.split('@')&.first || "Admin" %>
          </span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end mt-2 p-0"
            aria-labelledby="profileDropdown"
            style="min-width: 240px;">
          <%# ================= USER INFO ================= %>
          <li class="px-3 py-3 border-bottom">
            <div class="d-flex align-items-center gap-2">
              <div class="avatar avatar-sm bg-gradient-info rounded-circle d-flex align-items-center justify-content-center"
                   style="width: 36px; height: 36px; min-width: 36px;">
                <span class="text-white text-sm font-weight-bold">
                  <%= current_admin_user&.email&.first&.upcase %>
                </span>
              </div>
              <div>
                <div class="text-sm font-weight-bold text-dark lh-1 mb-1">
                  <%= current_admin_user&.email&.split('@')&.first&.capitalize %>
                </div>
                <div class="text-xs text-muted">
                  <%= current_admin_user&.email %>
                </div>
                <div class="text-xs mt-1">
                  <% if is_super_admin %>
                    <span class="text-warning font-weight-bold">
                      <i class="material-symbols-rounded" style="font-size:12px;">shield</i>
                      <%= current_admin_user.role.display_name %>
                    </span>
                  <% else %>
                    <span class="text-info font-weight-bold">
                      <i class="material-symbols-rounded" style="font-size:12px;">manage_accounts</i>
                      <%= current_admin_user.role.display_name %>
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
          </li>
          <%# ================= ROLE-BASED LINKS ================= %>
          <% if is_super_admin %>
            <li>
              <%= link_to admin_accounts_path,
                  class: "dropdown-item d-flex align-items-center gap-2 px-3 py-2" do %>
                <i class="material-symbols-rounded fs-5">group</i>
                <span>Manage Admins</span>
              <% end %>
            </li>
            <li>
              <%= link_to admin_permissions_path,
                  class: "dropdown-item d-flex align-items-center gap-2 px-3 py-2" do %>
                <i class="material-symbols-rounded fs-5">admin_panel_settings</i>
                <span>Permissions</span>
              <% end %>
            </li>
          <% end %>
          <%# ================= LOGOUT ================= %>
          <li class="border-top">
            <%= link_to destroy_admin_user_session_path,
                method: :delete,
                data: { turbo_method: :delete, turbo_confirm: "Logout?" },
                class: "dropdown-item d-flex align-items-center gap-2 text-danger px-3 py-2" do %>
              <i class="material-symbols-rounded fs-5">logout</i>
              <span>Logout</span>
            <% end %>
          </li>
        </ul>
      </li>
    </ul>
  </div>
</nav>