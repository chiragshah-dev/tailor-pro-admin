<nav class="navbar navbar-main navbar-expand-lg bg-white px-4 py-1 shadow-sm border-radius-xl mt-2 pt-2 custom-navbar m-auto" style="width: 97%;">
  <div class="container-fluid d-flex align-items-center justify-content-between">
    <!-- LEFT : Breadcrumb + Page Title -->
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent mb-1 p-0">
          <% dynamic_breadcrumbs.each_with_index do |crumb, i| %>
            <% last = i == dynamic_breadcrumbs.size - 1 %>
            <li class="breadcrumb-item text-sm <%= 'text-dark active' if last %>">
              <% if last || crumb[:path].blank? %>
                <span><%= crumb[:label] %></span>
              <% else %>
                <%= link_to crumb[:label], crumb[:path], class: "text-muted" %>
              <% end %>
            </li>
          <% end %>
        </ol>
      </nav>
    </div>
    <!-- RIGHT : Profile Dropdown -->
    <ul class="navbar-nav">
      <li class="nav-item d-xl-none ps-3 d-flex align-items-center">
        <a href="javascript:;" class="nav-link text-body p-0" id="iconNavbarSidenav">
          <div class="sidenav-toggler-inner">
            <i class="sidenav-toggler-line"></i>
            <i class="sidenav-toggler-line"></i>
            <i class="sidenav-toggler-line"></i>
          </div>
        </a>
      </li>
      <li class="nav-item dropdown">
        <a class="nav-link d-flex align-items-center gap-2 px-3 py-2 rounded"
           href="#"
           id="profileDropdown"
           role="button"
           data-bs-toggle="dropdown"
           aria-expanded="false">
          <i class="material-symbols-rounded fs-4">account_circle</i>
          <span class="text-sm ">
            <%= current_admin_user&.email&.split('@')&.first || "Admin" %>
          </span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end mt-2 p-0"
    aria-labelledby="profileDropdown"
    style="min-width: 220px;">
          <!-- USER INFO -->
          <li class="px-3 py-2 border-bottom">
            <div class="text-xs text-muted">Signed in as</div>
            <div class="text-sm  text-dark">
              <%= current_admin_user&.email || "admin@example.com" %>
            </div>
          </li>
          <!-- LOGOUT -->
          <li>
            <%= link_to destroy_admin_user_session_path,
          method: :delete,
          data: { turbo_method: :delete , turbo_confirm: "Are you sure you want to logout?"},
          class: "dropdown-item d-flex align-items-center gap-2 text-dark px-3 py-2" do %>
              <i class="material-symbols-rounded fs-5">logout</i>
              <span>Logout</span>
            <% end %>
          </li>
        </ul>
      </li>
    </ul>
  </div>
</nav>