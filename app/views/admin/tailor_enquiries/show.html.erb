<div class="row">
  <div class="col-12">
    <!-- PAGE HEADER -->
    <div class="card my-4">
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3 d-flex justify-content-between align-items-center">
          <h6 class="text-white text-capitalize ps-3 mb-0">
            Tailor Enquiry Details
          </h6>
          <div class="me-3 d-flex gap-2">
            <%= button_to admin_tailor_enquiry_path(@tailor_enquiry, page: params[:page]),
              method: :delete,
              class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold",
              data: { turbo_confirm: "Are you sure you want to delete this enquiry?" } do %>
              Delete
            <% end %>
          </div>
        </div>
        <!-- DETAILS BODY -->
        <div class="card-body px-4 pt-4 pb-2">
          <div class="row">
            <!-- LEFT COLUMN -->
            <div class="col-md-6">
              <p class="text-sm mb-2">
                <span class="fw-bold text-dark">Name:</span>
                <span class="text-sm text-dark mb-0 ms-2">
                  <%= @tailor_enquiry.name.presence || "-" %>
                </span>
              </p>
              <p class="text-sm mb-2">
                <span class="fw-bold text-dark">Email:</span>
                <span class="text-sm text-dark mb-0 ms-2">
                  <%= @tailor_enquiry.email.presence || "-" %>
                </span>
              </p>
            </div>
            <!-- RIGHT COLUMN -->
            <div class="col-md-6">
              <p class="text-sm mb-2">
                <span class="fw-bold text-dark">Created At:</span>
                <span class="text-sm text-dark mb-0 ms-2">
                  <%= @tailor_enquiry.created_at.strftime("%d %b %Y %I:%M %p") %>
                </span>
              </p>
            </div>
          </div>
          <!-- BACK BUTTON -->
          <%= link_to admin_tailor_enquiries_path(page: params[:page]),
            class: "btn btn-secondary btn-sm text-uppercase font-weight-bold float-end" do %>
            Back
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
