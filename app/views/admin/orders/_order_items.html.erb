<turbo-frame id="order_items_frame">
  <h6 class="text-uppercase text-dark mb-3">Order Items</h6>
  <small class=" text-dark font-weight-bold text-xs mb-2">
    Showing <%= @order_items.offset_value + 1 %> -
    <%= @order_items.offset_value + @order_items.size %>
    of <%= @order_items.total_count %> results
  </small>
  <div class="card my-2">
    <div class="card-body px-0 pb-2">
      <div class="table-responsive p-0">
        <table class="table align-items-center mb-0">
          <thead>
            <tr>
              <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">ID</th>
              <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">Item No</th>
              <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">Work</th>
              <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">For</th>
              <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">Garment</th>
              <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">Qty</th>
              <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">Unit Price</th>
              <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">Worker</th>
              <th class="text-center text-uppercase text-secondary text-xxs font-weight-bold">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if @order_items.any?%>
              <% @order_items.each_with_index do |item, index| %>
                <tr>
                  <td class="text-center text-dark text-sm ">
                    <%= @order_items.offset_value + index + 1 %>
                  </td>
                  <td class="text-center text-dark text-sm ">
                    <%= item.order_item_number %>
                  </td>
                  <td class="text-center text-dark text-sm text-capitalize">
                    <%= item.work_type %>
                  </td>
                  <td class="text-center text-dark text-sm text-capitalize">
                    <%= item.stichfor %>
                  </td>
                  <td class="text-center text-dark text-sm">
                    <%= item.garment_type&.garment_name || "-" %>
                  </td>
                  <td class="text-center text-dark text-sm">
                    <%= item.quantity %>
                  </td>
                  <td class="text-center text-dark text-sm">
                    ₹ <%= item.price %>
                  </td>
                  <td class="text-center text-dark text-sm">
                    <%= item.worker&.name || "-" %>
                  </td>
                  <!-- ACTION -->
                  <td class="text-center">
                    <%= link_to admin_order_item_path(item),
                        class: "btn btn-xs rounded btn-secondary",
                        title: "Show",
                        data: { turbo_frame: "_top" } do %>
                      <i class="fas fa-eye"></i>
                    <% end %>
                    <%= link_to history_admin_order_item_path(item),  
                        class: "btn btn-xs rounded btn-secondary",
                        title: "History",
                        data: { turbo_frame: "_top" } do %>
                      <i class="fas fa-history"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <%else%>
              <tr>
                <td colspan="12" class="text-center">
                  <p class="no-content-text">No records found.</p>
                </td>
              </tr>
            <%end%>
            <!-- Pagination -->
            <tr>
              <td colspan="11" class="text-center py-3">
                <%= paginate @order_items,
              param_name: :items_page,
              link_options: {
                data: {
                  turbo_frame: "order_items_frame",
                  turbo_prefetch: "false"
                }
              } %>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</turbo-frame>
