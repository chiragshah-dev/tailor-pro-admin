<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="card mb-4">
        <!-- PAGE HEADER -->
        <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
          <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3
                      d-flex justify-content-between align-items-center">
            <h6 class="text-white text-capitalize ps-3 mb-0">
              Order Details
            </h6>
          </div>
        </div>
        <!-- ORDER DETAILS BODY -->
        <div class="card-body px-4 pt-4 pb-4">
          <!-- BASIC INFO -->
          <div class="row mb-3">
            <!-- LEFT -->
            <div class="col-md-6">
              <p class="text-sm mb-2 text-dark">
                <strong>Order ID:</strong>
                <span class="text-secondary ms-2"><%= @order.id %></span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Order Number:</strong>
                <span class="text-secondary ms-2"><%= @order.order_number %></span>
              </p>
           
             
              <p class="text-sm mb-2 text-dark">
                <strong>Order Date:</strong>
                <span class="text-secondary ms-2"><%= @order.order_date %></span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Status:</strong>
                <span class="ms-2"><%= order_status_badge(@order.status) %></span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Payment Status:</strong>
                <span class="ms-2"><%= payment_status_badge(@order.payment_status) %></span>
              </p>
            </div>
            <!-- RIGHT -->
            <div class="col-md-6">
              <p class="text-sm mb-2 text-dark">
                <strong>Customer:</strong>
                <span class="text-secondary ms-2">
                  <%= @order.customer&.name || "-" %>
                </span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Store:</strong>
                <span class="text-secondary ms-2">
                  <%= @order.store&.name || "-" %>
                </span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Assigned Worker:</strong>
                <span class="text-secondary ms-2">
                  <%= @order.worker&.name || "-" %>
                </span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Assigned At:</strong>
                <span class="text-secondary ms-2">
                  <%= @order.assigned_at || "-" %>
                </span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Delivery Date:</strong>
                <span class="text-secondary ms-2">
                  <%= @order.delivery_date || "-" %>
                </span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Courier To Customer:</strong>
                <span class="text-secondary ms-2">
                  <%= @order.courier_to_customer ? "Yes" : "No" %>
                </span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Transaction ID:</strong>
                <span class="text-secondary ms-2">
                  <%= @order.transaction_id || "-" %>
                </span>
              </p>
            </div>
          </div>
          <hr class="horizontal dark my-3">
          <!-- PAYMENT DETAILS -->
          <h6 class="text-uppercase text-dark mb-3">Payment Details</h6>
          <div class="row mb-3">
            <div class="col-md-6">
              <p class="text-sm mb-2 text-dark">
                <strong>Total Bill Amount:</strong>
                <span class="text-secondary ms-2">₹ <%= @order.total_bill_amount %></span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Advance Paid:</strong>
                <span class="text-secondary ms-2">₹ <%= @order.advance_payment %></span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Payment Received:</strong>
                <span class="text-secondary ms-2">₹ <%= @order.payment_received %></span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Additional Price:</strong>
                <span class="text-secondary ms-2">₹ <%= @order.additional_price %></span>
              </p>
            </div>
            <div class="col-md-6">
              <p class="text-sm mb-2 text-dark">
                <strong>Discount:</strong>
                <span class="text-secondary ms-2">₹ <%= @order.discount %></span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Balance Due:</strong>
                <span class="text-secondary ms-2">₹ <%= @order.balance_due %></span>
              </p>
              <p class="text-sm mb-2 text-dark">
                <strong>Payment Type:</strong>
                <span class="text-secondary ms-2 text-capitalize">
                  <%= @order.payment_type %>
                </span>
              </p>
            </div>
          </div>
          <hr class="horizontal dark my-3">
          <!-- ORDER ITEMS -->
          <%= render "order_items" %>
          <!-- BACK -->
          <%= link_to admin_orders_path,
              class: "btn btn-secondary btn-sm text-uppercase font-weight-bold float-end mt-3",
              data: { turbo_frame: "_top" } do %>
            Back
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
