<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="card my-4">
        <!-- HEADER -->
        <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
          <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
            <h6 class="text-white text-capitalize ps-3 mb-0">
              Country Code
            </h6>
          </div>
        </div>
        <!-- BODY -->
        <div class="card-body px-4 pb-4">
          <%= form_with model: @currency_country,
                        url: @currency_country.persisted? ?
                             admin_currency_country_path(@currency_country) :
                             admin_currency_countries_path,
                        local: true do |f| %>
            <div class="row g-4">
              <!-- Country Name -->
              <div class="col-md-6">
                <label class="form-label font-weight-bold text-dark">Country Name</label>
                <div class="input-group input-group-outline">
                  <%= f.text_field :country_name, class: "form-control", placeholder: "Enter Country Name" %>
                </div>
                <div class="text-danger mt-2 text-xs">
                  <%= @currency_country.errors.full_messages_for(:country_name).first %>
                </div>
              </div>
              <!-- Country Dialing Code -->
              <div class="col-md-6">
                <label class="form-label font-weight-bold text-dark">Dialing Code</label>
                <div class="input-group input-group-outline">
                  <%= f.text_field :country_code, class: "form-control", placeholder: "+91" %>
                </div>
                <div class="text-danger mt-2 text-xs">
                  <%= @currency_country.errors.full_messages_for(:country_code).first %>
                </div>
              </div>
              <!-- Currency -->
              <div class="col-md-6">
                <label class="form-label font-weight-bold text-dark">Currency</label>
                <div class="input-group input-group-outline">
                  <%= f.select :currency_id,
                        options_from_collection_for_select(
                          Currency.order(:name),
                          :id,
                          :name,
                          @currency_country.currency_id
                        ),
                        { prompt: "Select Currency" },
                        class: "form-control #{'is-invalid' if @currency_country.errors[:currency_id].any?}" %>
                </div>
                <div class="text-danger mt-2 text-xs">
                  <%= @currency_country.errors.full_messages_for(:currency_id).first %>
                </div>
              </div>
            </div>
            <!-- ACTIONS -->
            <div class="d-flex justify-content-end mt-4">
              <%= link_to "Back",
                    admin_currency_countries_path,
                    class: "btn btn-secondary me-2 text-uppercase font-weight-bold" %>
              <%= f.submit "Save",
                    class: "btn btn-info text-white text-uppercase font-weight-bold" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  document.addEventListener("turbo:load", () => {
    const form = document.querySelector("form");
    if (!form) return;

    const countryName   = document.getElementById("currency_country_country_name");
    const countryCode   = document.getElementById("currency_country_country_code");
    const currencyId    = document.getElementById("currency_country_currency_id");

    const nameRegex     = /^[A-Za-z\s]+$/;
    const codeRegex     = /^\+\d{1,5}$/;

    form.addEventListener("submit", (e) => {
      clearErrors();
      let valid = true;

      // Country Name
      if (!countryName.value.trim()) {
        showError(countryName, "Country name is required");
        valid = false;
      } else if (!nameRegex.test(countryName.value.trim())) {
        showError(countryName, "Country name must contain only letters");
        valid = false;
      }

      // Dialing Code
      if (!countryCode.value.trim()) {
        showError(countryCode, "Dialing code is required");
        valid = false;
      } else if (!codeRegex.test(countryCode.value.trim())) {
        showError(countryCode, "Enter valid dialing code (e.g. +91)");
        valid = false;
      }

      // Currency
      if (!currencyId.value) {
        showError(currencyId, "Currency is required");
        valid = false;
      }

      if (!valid) e.preventDefault();
    });

    function showError(element, message) {
      element.classList.add("is-invalid");

      const error = document.createElement("small");
      error.className = "text-danger validation-error";
      error.innerText = message;

      element.closest(".input-group").after(error);
    }

    function clearErrors() {
      document.querySelectorAll(".validation-error").forEach(el => el.remove());
      document.querySelectorAll(".is-invalid").forEach(el => el.classList.remove("is-invalid"));
    }
  });
</script>
