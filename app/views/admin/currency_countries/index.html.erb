<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3 d-flex justify-content-between">
          <h6 class="text-white ps-3 mb-0">Country Code</h6>
          <%= link_to "Add New Country Code",
      new_admin_currency_country_path,
      class: "btn btn-sm btn-white text-dark me-3 text-uppercase font-weight-bold" %>
        </div>
      </div>
      <div class="card-body px-0 pb-2">
        <div class="px-3 pb-3">
          <%= render "admin/shared/search",
                    url: admin_currency_countries_path,
                    placeholder: "Search country codes..." %>
        </div>
        <div class="table-responsive p-0">
          <table class="table align-items-center mb-0">
            <thead>
              <tr>
                <th class="text-uppercase text-dark text-xxs font-weight-bold">ID</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Country Code</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Country Name</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Currency Name</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2 text-center">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if @currency_countries.present? %>
                <% @currency_countries.each_with_index do |currency_country, index| %>
                  <tr>
                    <td class="px-3">
                      <p class="text-xs font-weight-bold mb-0 px-3 py-1">
                        <%= (@currency_countries.current_page - 1) * @currency_countries.limit_value + index + 1 %>
                      </p>
                    </td>
                    <td>
                      <p class="text-sm text-secondary mb-0 font-weight-bold">
                        <h6 class="mb-0 text-sm"><%= currency_country.country_code %></h6>
                      </p>
                    </td>
                    <td>
                      <p class="text-sm text-secondary mb-0 font-weight-bold">
                        <h6 class="mb-0 text-sm"><%= currency_country.country_name %></h6>
                      </p>
                    </td>
                    <td>
                      <p class="text-sm text-secondary mb-0 font-weight-bold">
                        <h6 class="mb-0 text-sm"><%= currency_country.currency.name %></h6>
                      </p>
                    </td>
                    <td class="align-middle text-center">
                      <div class="d-flex justify-content-center gap-1">
                        <%= link_to edit_admin_currency_country_path(currency_country,page: params[:page]),
                                  class: "btn btn-xs rounded btn-secondary",
                                  title: "Edit" do %>
                          <i class="fas fa-edit"></i>
                        <% end %>
                        <%= button_to admin_currency_country_path(currency_country,page: params[:page]),
                                  method: :delete,
                                  onclick: "return confirm('Are you sure you want to delete this #{currency_country.country_name}?')",
                                  class: "btn btn-xs rounded btn-secondary",
                                  form: { class: "d-inline" },
                                  title: "Delete" do %>
                          <i class="fas fa-trash"></i>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="12" class="text-center">
                    <p class="no-content-text">No records found.</p>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="d-flex justify-content-center px-3 mt-3">
          <%= paginate @currency_countries %>
        </div>
      </div>
    </div>
  </div>
</div>
