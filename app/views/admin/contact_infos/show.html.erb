<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3 d-flex justify-content-between align-items-center">
          <h6 class="text-white text-capitalize ps-3 mb-0">
            Contact Info Details
          </h6>
          <div class="me-3 d-flex gap-2">
            <%= link_to edit_admin_contact_info_path(@contact_info, page: params[:page]),
                  class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold" do %>
              Edit
            <% end %>
            <%= button_to admin_contact_info_path(@contact_info, page: params[:page]),
                  method: :delete,
                  class: "btn btn-sm btn-white text-dark text-uppercase font-weight-bold",
                  data: { turbo_confirm: "Are you sure you want to delete #{@contact_info.contact_number}?" } do %>
              Delete
            <% end %>
          </div>
        </div>
      </div>
      <!-- BODY -->
      <div class="card-body px-4 pt-4 pb-2">
        <div class="row">
          <div class="col-md-6">
            <p class="text-sm mb-2">
              <span class="fw-bold text-dark">Contact Number:</span>
              <span class="text-sm text-dark mb-0 ms-2">
                <%= @contact_info.contact_number %>
              </span>
            </p>
            <p class="text-sm mb-2">
              <span class="fw-bold text-dark">Email:</span>
              <span class="text-sm text-dark mb-0  ms-2">
                <%= @contact_info.email %>
              </span>
            </p>
          </div>
          <div class="col-md-6">
            <p class="text-sm mb-2">
              <span class="fw-bold text-dark">Website URL:</span>
              <span class="text-sm text-dark mb-0  ms-2">
                <%= @contact_info.website_url %>
              </span>
            </p>
            <p class="text-sm mb-2">
              <span class="fw-bold text-dark">Address:</span>
              <span class="text-sm text-dark mb-0  ms-2">
                <%= @contact_info.address %>
              </span>
            </p>
          </div>
        </div>
        <!-- ACTIONS -->
        <div class="d-flex justify-content-end">
          <%= link_to admin_contact_infos_path(page: params[:page]),
                class: "btn btn-secondary btn-sm text-uppercase font-weight-bold" do %>
            Back
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
