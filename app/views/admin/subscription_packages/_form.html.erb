<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
          <h6 class="text-white text-capitalize ps-3 mb-0">
            <%= @subscription_package.new_record? ? "New Package" : "Edit Package" %>
          </h6>
        </div>
      </div>
      <!-- BODY -->
      <div class="card-body px-4 pb-4">
        <%= form_with model: [:admin, @subscription_package], local: true do |f| %>
          <%= hidden_field_tag :page, params[:page] %>
          <div class="row g-4">
            <!-- Name -->
            <div class="col-md-6">
              <label class="form-label font-weight-bold text-dark">Package Name</label>
              <div class="input-group input-group-outline">
                <%= f.text_field :name, class: "form-control", id: "package_name" %>
              </div>
              <div id="name_err" class="text-danger text-xs mt-2">
                <%= @subscription_package.errors.full_messages_for(:name).first %>
              </div>
            </div>
            <!-- Currency -->
            <div class="col-md-6">
              <label class="form-label font-weight-bold text-dark">Currency</label>
              <div class="input-group input-group-outline">
                <%= f.select :currency,
                  options_for_select(SubscriptionPackage::CURRENCIES, @subscription_package.currency),
                  {},
                  class: "form-control",
                  id: "package_currency" %>
              </div>
            </div>
            <!-- Billing Type -->
            <div class="col-md-6">
              <label class="form-label font-weight-bold text-dark">Billing Type</label>
              <div class="input-group input-group-outline">
                <%= f.select :billing_type,
                  options_for_select(SubscriptionPackage::BILLING_TYPES.map { |t| [t.capitalize, t] }, @subscription_package.billing_type),
                  {},
                  class: "form-control",
                  id: "package_billing_type" %>
              </div>
            </div>
            <!-- Invoice Fee -->
            <div class="col-md-3">
              <label class="form-label font-weight-bold text-dark">Invoice Fee (%)</label>
              <div class="input-group input-group-outline">
                <%= f.number_field :invoice_fee_percent,
                  step: 0.01,
                  class: "form-control",
                  id: "invoice_fee" %>
              </div>
              <div id="invoice_err" class="text-danger text-xs mt-2">
                <%= @subscription_package.errors.full_messages_for(:invoice_fee_percent).first %>
              </div>
            </div>
            <!-- free order amount limit -->
            <div class="col-md-3">
              <label class="form-label font-weight-bold text-dark">Free Order Amount Limit</label>
              <div class="input-group input-group-outline">
                <%= f.number_field :amount_limit,
                  step: 0.01,
                  class: "form-control",
                  id: "amount_limit" %>
              </div>
              <div id="amount_limit_err" class="text-danger text-xs mt-2">
                <%= @subscription_package.errors.full_messages_for(:amount_limit).first %>
              </div>
            </div>
            <!-- Monthly Price -->
            <div class="col-md-6">
              <label class="form-label font-weight-bold text-dark">Monthly Price (₹)</label>
              <div class="input-group input-group-outline">
                <%= f.number_field :price_month,
                  step: 0.01,
                  class: "form-control",
                  id: "price_month" %>
              </div>
              <div id="month_err" class="text-danger text-xs mt-2">
                <%= @subscription_package.errors.full_messages_for(:price_month).first %>
              </div>
            </div>
            <!-- Yearly Price -->
            <div class="col-md-6">
              <label class="form-label font-weight-bold text-dark">Yearly Price (₹)</label>
              <div class="input-group input-group-outline">
                <%= f.number_field :price_year,
                  step: 0.01,
                  class: "form-control",
                  id: "price_year" %>
              </div>
              <div id="year_err" class="text-danger text-xs mt-2">
                <%= @subscription_package.errors.full_messages_for(:price_year).first %>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label font-weight-bold text-dark">RazorPay PlanID Monthly</label>
              <div class="input-group input-group-outline">
                <%= f.text_field :razorpay_plan_id_monthly, class: "form-control", id: "razorpay_plan_id_monthly" %>
              </div>
              <div id="razorpay_plan_id_monthly_err" class="text-danger text-xs mt-2">
                <%= @subscription_package.errors.full_messages_for(:razorpay_plan_id_monthly).first %>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label font-weight-bold text-dark">RazorPay PlanID Yearly</label>
              <div class="input-group input-group-outline">
                <%= f.text_field :razorpay_plan_id_yearly, class: "form-control", id: "razorpay_plan_id_yearly" %>
              </div>
              <div id="razorpay_plan_id_yearly_err" class="text-danger text-xs mt-2">
                <%= @subscription_package.errors.full_messages_for(:razorpay_plan_id_yearly).first %>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label font-weight-bold text-dark">IOS ProductId Monthly</label>
              <div class="input-group input-group-outline">
                <%= f.text_field :ios_product_id_monthly, class: "form-control", id: "ios_product_id_monthly" %>
              </div>
              <div id="ios_product_id_monthly_err" class="text-danger text-xs mt-2">
                <%= @subscription_package.errors.full_messages_for(:ios_product_id_monthly).first %>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label font-weight-bold text-dark">IOS ProductId Yearly</label>
              <div class="input-group input-group-outline">
                <%= f.text_field :ios_product_id_yearly, class: "form-control", id: "ios_product_id_yearly" %>
              </div>
              <div id="ios_product_id_yearly_err" class="text-danger text-xs mt-2">
                <%= @subscription_package.errors.full_messages_for(:ios_product_id_yearly).first %>
              </div>
            </div>
            <!-- Description -->
            <div class="col-12">
              <label class="form-label font-weight-bold text-dark">Description</label>
              <div>
                <div id="editor" style="height: 200px; background-color: #fff; border: 1px solid #ced4da; border-radius: 0.25rem;"></div>
                <%= f.hidden_field :description, id: "description" %>
              </div>
            </div>
            <!-- message -->
            <div class="col-12">
              <label class="form-label font-weight-bold text-dark">Message</label>
              <div class="input-group input-group-outline">
                <%= f.text_field :message, class: "form-control" %>
              </div>
              <div id="message_err" class="text-danger text-xs mt-2">
                <%= @subscription_package.errors.full_messages_for(:message).first %>
              </div>
            </div>
            <!-- Active -->
            <div class="col-12">
              <label class="form-label font-weight-bold text-dark">Status</label>
              <div class="form-check mt-2">
                <%= f.check_box :active, class: "form-check-input", id: "active_checkbox" %>
                <label class="form-check-label" for="active_checkbox">Active</label>
              </div>
            </div>
            <!-- Best Choice -->
            <div class="col-12">
              <label class="form-label font-weight-bold text-dark">Best Choice</label>
              <div class="form-check mt-2">
                <%= f.check_box :best_choice, class: "form-check-input", id: "best_choice_checkbox" %>
                <label class="form-check-label" for="best_choice_checkbox">Active</label>
              </div>
            </div>
            <hr class="my-4">
            <!-- ICON / IMAGE -->
            <h6 class="text-uppercase text-dark mb-3">Package Icon</h6>
            <div class="form-group col-md-6">
              <% if f.object.icon.attached? %>
                <div class="mb-2">
                  <%= image_tag f.object.icon,
                          class: "img-thumbnail",
                          style: "max-width: 120px;" %>
                </div>
              <% end %>
              <div class="d-flex align-items-center gap-2">
                <label class="btn bg-gradient-info text-white mb-0">
                  Choose Icon
                  <%= f.file_field :icon,
                          class: "d-none",
                          accept: "image/png,image/jpeg,image/svg+xml",
                          onchange: "this.closest('.d-flex').querySelector('.file-name').innerText = this.files[0]?.name || 'No file chosen'" %>
                </label>
                <span class="file-name text-muted">No file chosen</span>
              </div>
              <p class="text-xs text-secondary mt-1">Accepted: PNG, JPG, SVG</p>
            </div>
          </div>
          <!-- ACTIONS -->
          <div class="d-flex justify-content-end mt-4">
            <%= link_to "Back",
              admin_subscription_packages_path(page: params[:page]),
              class: "btn btn-secondary me-2 text-uppercase font-weight-bold" %>
            <%= f.submit @subscription_package.new_record? ? "Create" : "Update",
              class: "btn btn-info text-white text-uppercase font-weight-bold" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
<!-- Quill Initialization -->
<script>
  document.addEventListener("turbo:load", () => {
    const form = document.querySelector("form");
    if (!form) return;

    const nameInput = document.getElementById("package_name");
    const nameErr   = document.getElementById("name_err");

    // Clear error on input
    nameInput?.addEventListener("input", () => {
      if (nameInput.value.trim()) {
        nameErr.innerHTML = "";
        nameInput.classList.remove("is-invalid");
      }
    });

    form.addEventListener("submit", (e) => {
      let valid = true;

      // Reset error
      nameErr.innerHTML = "";
      nameInput.classList.remove("is-invalid");

      // Validate Package Name
      if (!nameInput.value.trim()) {
        nameErr.innerHTML = "Package name can't be blank";
        nameInput.classList.add("is-invalid");
        valid = false;
      }

      if (!valid) e.preventDefault();
    });
  });
  document.addEventListener("turbo:load", () => {
    const editorContainer = document.querySelector('#editor');

    if (editorContainer && !editorContainer.classList.contains("ql-container")) {
      const quill = new Quill('#editor', {
        theme: 'snow',
        placeholder: 'Write description...',
        modules: {
          toolbar: [
            [{ 'list': 'ordered' }, { 'list': 'bullet' }],
            ['bold', 'italic', 'underline'],
            ['link']
          ]
        }
      });

      // Load existing content (edit page)
      const hiddenInput = document.querySelector('#description');
      if (hiddenInput.value) {
        quill.root.innerHTML = hiddenInput.value;
      }

      // Sync to hidden field before submit
      const form = editorContainer.closest("form");
      form.addEventListener("submit", () => {
        hiddenInput.value = quill.root.innerHTML.trim();
      });

      // Store reference for cleanup
      editorContainer._quill = quill;
    }
  });

  // Cleanup for Turbo cache
  document.addEventListener("turbo:before-cache", () => {
    const editorContainer = document.querySelector('#editor');
    if (editorContainer) {
      if (editorContainer._quill) {
        editorContainer._quill.destroy();
      }
      editorContainer.innerHTML = "";
    }
  });
</script>
