<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <!-- HEADER -->
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
          <h6 class="text-white text-capitalize ps-3">Contact Supports</h6>
        </div>
      </div>
      <!-- BODY -->
      <div class="card-body px-0 pb-2">
        <!-- SEARCH -->
        <div class="px-3 pb-3">
          <%= render "admin/shared/search",
            url: admin_contact_supports_path,
            placeholder: "Search supports..." %>
        </div>
        <!-- TABLE -->
        <div class="table-responsive p-0">
          <table class="table align-items-center mb-0">
            <thead>
              <tr>
                <th class="text-uppercase text-dark text-xxs font-weight-bold">Id</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">User</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Email</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Subject</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Status</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold text-center">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if @contact_supports.present? %>
                <% @contact_supports.each_with_index do |support, index| %>
                  <tr>
                    <!-- ID -->
                    <td>
                      <p class="text-sm text-dark mb-0 px-3 py-1">
                        <%= (@contact_supports.current_page - 1) *
                            @contact_supports.limit_value + index + 1 %>
                      </p>
                    </td>
                    <!-- USER -->
                    <td>
                      <div class="d-flex flex-column justify-content-center">
                        <p class="mb-0 text-sm text-dark">
                          <%= support.user&.name || "-" %>
                        </p>
                      </div>
                    </td>
                    <!-- EMAIL -->
                    <td>
                      <p class="text-sm text-dark mb-0 ">
                        <%= support.email %>
                      </p>
                    </td>
                    <!-- SUBJECT -->
                    <td>
                      <p class="text-sm text-dark mb-0 ">
                        <%= support.subject %>
                      </p>
                    </td>
                    <!-- STATUS -->
                    <td class="align-middle">
                      <% if support.open? %>
                        <%= button_to close_admin_contact_support_path(support, page: params[:page]),
  method: :patch,
  form: {
    data: {
      turbo_confirm: "Are you sure you want to close this request?",
      confirm_ok: "Close"
    }
  },
  class: "btn btn-xs bg-gradient-danger font-weight-bold text-white d-flex align-items-center justify-content-center" do %>
                          OPEN
                        <% end %>
                      <% else %>
                        <button
      class="btn btn-xs bg-gradient-success font-weight-bold text-white d-flex align-items-center justify-content-center
      "
      disabled>
                          CLOSED
                        </button>
                      <% end %>
                    </td>
                    <!-- ACTIONS -->
                    <td class="align-middle text-center">
                      <div class="d-flex justify-content-center gap-1">
                        <%= link_to admin_contact_support_path(support, page: params[:page]),
                          class: "btn btn-xs rounded btn-secondary",
                          title: "Show" do %>
                          <i class="fas fa-eye"></i>
                        <% end %>
                        <%#= button_to admin_contact_support_path(support, page: params[:page]),
                          method: :delete,
                          class: "btn btn-xs rounded btn-secondary",
                          data: { turbo_confirm: "Are you sure?" } do %>
                          <%# <i class="fas fa-trash"></i> %>
                          <%# end %>
                          <%= link_to history_admin_contact_support_path(support),
                          class: "btn btn-xs rounded btn-secondary",
                          title: "View History" do %>
                            <i class="fas fa-history"></i>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="12" class="text-center">
                      <p class="no-content-text">No records found.</p>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <!-- PAGINATION -->
          <div class="d-flex justify-content-center px-3 mt-3">
            <%= paginate @contact_supports %>
          </div>
        </div>
      </div>
    </div>
  </div>
