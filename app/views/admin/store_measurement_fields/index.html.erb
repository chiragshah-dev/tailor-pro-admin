<div class="row">
  <div class="col-12">
    <div class="card my-4">
      <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
        <div class="bg-gradient-info shadow-info border-radius-lg pt-4 pb-3">
          <h6 class="text-white text-capitalize ps-3">
            Store Measurement Fields
          </h6>
        </div>
      </div>
      <div class="card-body px-0 pb-2">
        <!-- Search -->
        <div class="px-3 pb-3">
          <%= render "admin/shared/search",
                url: admin_store_measurement_fields_path(store_id: params[:store_id]),
                placeholder: "Search measurement fields..." %>
        </div>
        <div class="table-responsive p-0">
          <table class="table align-items-center mb-0">
            <thead>
              <tr>
                <th class="text-uppercase text-dark text-xxs font-weight-bold">Id</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Name</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Label</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Store</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Garment Type</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold ps-2">Custom</th>
                <th class="text-uppercase text-dark text-xxs font-weight-bold text-center">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if @store_measurement_fields.present? %>
                <% @store_measurement_fields.each_with_index do |field, index| %>
                  <tr>
                    <!-- ID -->
                    <td>
                      <p class="text-sm text-dark mb-0 px-3 py-1">
                        <%= (@store_measurement_fields.current_page - 1) *
                            @store_measurement_fields.limit_value + index + 1 %>
                      </p>
                    </td>
                    <!-- Name -->
                    <td>
                      <p class="mb-0 text-sm text-dark">
                        <%= field.name.presence || "-" %>
                      </p>
                    </td>
                    <!-- Label -->
                    <td>
                      <p class="mb-0 text-sm text-dark">
                        <%= field.label.presence || "-" %>
                      </p>
                    </td>
                    <!-- Store -->
                    <td>
                      <% if field.store.present? %>
                        <%= link_to admin_store_path(field.store),
                              class: "text-info",
                              title: "Show Store" do %>
                          <%= field.store.name %>
                        <% end %>
                      <% else %>
                        <span>-</span>
                      <% end %>
                    </td>
                    <!-- Garment Type -->
                    <td>
                      <p class="mb-0 text-sm text-dark">
                        <%= field.garment_type&.garment_name || "-" %>
                      </p>
                    </td>
                    <!-- Edited -->
                    <td>
                      <p class="mb-0 text-sm text-dark">
                        <%= field.custom.to_s.capitalize %>
                      </p>
                    </td>
                    <!-- Actions -->
                    <td class="align-middle text-center">
                      <div class="d-flex justify-content-center gap-1">
                        <%= link_to admin_store_measurement_field_path(field, page: params[:page]),
                              class: "btn btn-xs rounded btn-secondary",
                              title: "Show" do %>
                          <i class="fas fa-eye"></i>
                        <% end %>
                        <%#= button_to admin_store_measurement_field_path(field, page: params[:page]),
                              method: :delete,
                              class: "btn btn-xs rounded btn-secondary",
                              data: { turbo_confirm: "Are you sure you want to delete #{field.name}?" } do %>
                          <%# <i class="fas fa-trash"></i> %>
                          <%# end %>
                          <%= link_to history_admin_store_measurement_field_path(field),
                              class: "btn btn-xs rounded btn-secondary",
                              title: "View History" do %>
                            <i class="fas fa-history"></i>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="12" class="text-center">
                      <p class="no-content-text">No records found.</p>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <!-- Pagination -->
          <div class="d-flex justify-content-center px-3 mt-3">
            <%= paginate @store_measurement_fields %>
          </div>
        </div>
      </div>
    </div>
  </div>
