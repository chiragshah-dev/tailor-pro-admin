<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Tailors Pro – Free Mobile Tailoring App | Manage Orders & Measurements</title>
    <meta charset="utf-8" />
    <meta name="description" content="Free Mobile App for Tailoring shop,Tailorspro App,Free Tailoring shop software, CRM, ERP, Software, Mobile, Desktop, tailoring business software, Tailor App, Tailoring App, Manage Order, Customers, Measurements, Android app for Tailors, Tailoring Mobile App, India, USA">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" href="<%= image_path('favicon.ico') %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="turbo-prefetch" content="false">
    <!-- Google Fonts -->
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700,900|Roboto+Slab:400,700"/>
    <!-- Material Icons -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"/>
    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <!-- Rails CSS -->
    <%# <%= stylesheet_link_tag "application", data: { turbo_track: "reload" } %>
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="g-sidenav-show  bg-gray-100">
    <!-- End Navbar -->
    <% if controller_path == "admin/sessions" %>
      <!-- Login page -->
      <%= yield %>
    <% else %>
      <div class="container-fluid py-2">
        <%= render "admin/shared/turbo_confirm_modal" %>
        <%= render 'admin/shared/flash' %>
        <%= render "admin/shared/sidebar" %>
        <main class="main-content position-relative max-height-vh-100 h-100 border-radius-lg ">
          <%= render "admin/shared/navbar" %>
          <div class="container-fluid py-4">
            <%= yield %>
          </div>
        </main>
        <footer class="footer pt-4">
          <div class="container-fluid">
            <div class="text-center text-sm text-muted">
              © <%= Time.current.year %> TailorPro
            </div>
          </div>
        </footer>
      </div>
    <% end %>
  </body>
</html>
